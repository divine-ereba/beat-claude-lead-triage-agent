    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n\n  const text =\n    item.json.output ||\n    item.json.text ||\n    item.json.response ||\n    item.json.answer ||\n    item.json.content ||\n    \"\";\n\n  const extract = (regex, fallback = \"\") => {\n    const match = text.match(regex);\n    return match ? match[1].trim() : fallback;\n  };\n\n  const decision = extract(\n    /Decision:\\s*(QUALIFY|NURTURE|REJECT|ESCALATE)/i,\n    \"ESCALATE\"\n  ).toUpperCase();\n\n  const owner = extract(\n    /Owner:\\s*(Sales|Operations|Compliance|Security|Support)/i,\n    \"Operations\"\n  );\n\n  const confidence = Number(\n    extract(\n      /Confidence:\\s*([0-9]*\\.?[0-9]+)/i,\n      \"0.50\"\n    )\n  );\n\n  const detectedIssues = extract(\n    /Detected Issues:\\s*(.+)/i,\n    \"None\"\n  );\n\n  const reason = extract(\n    /Reason:\\s*(.+)/i,\n    \"No reason provided.\"\n  );\n\n  return {\n    json: {\n\n      // Original lead fields\n      ...item.json,\n\n      // Parsed AI fields\n      decision,\n      owner,\n      confidence,\n      detectedIssues,\n      reason,\n\n      // Helper fields\n      needsHuman: decision === \"ESCALATE\",\n\n      isQualified: decision === \"QUALIFY\",\n      isNurture: decision === \"NURTURE\",\n      isRejected: decision === \"REJECT\",\n      isEscalated: decision === \"ESCALATE\",\n\n      // Raw response for debugging\n      aiRawResponse: text\n\n    }\n  };\n\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
